<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github" value="https://nuget.pkg.github.com/directiv13/index.json" />
  </packageSources>

  <!--
    Scopes which packages are resolved from which source. Without this, NuGet
    restore would try to query the "github" source (and fail to authenticate
    with the placeholder PAT below) even for packages that have nothing to do
    with it. With mapping in place, "github" is only consulted for packages
    matching Vludik.Arbitrage.*, so a placeholder/invalid token here does not
    break restores that don't need this feed.
  -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github">
      <package pattern="Vludik.Arbitrage.*" />
    </packageSource>
  </packageSourceMapping>

  <packageSourceCredentials>
    <github>
      <!--
        PLACEHOLDER: replace YOUR_GITHUB_PAT_HERE with a GitHub personal access
        token that has the "read:packages" scope, so this feed can be used to
        restore Vludik.Arbitrage.* packages. Do not commit a real token here -
        for local development, prefer an environment-variable-based override or
        a user-level NuGet.Config instead.
      -->
      <add key="Username" value="directiv13" />
      <add key="ClearTextPassword" value="YOUR_GITHUB_PAT_HERE" />
    </github>
  </packageSourceCredentials>
</configuration>
